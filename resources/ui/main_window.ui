<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="windowTitle">
   <string>MINFLUX Data Viewer</string>
  </property>
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>680</width>
    <height>110</height>
   </rect>
  </property>
  <property name="acceptDrops">
   <bool>true</bool>
  </property>

  <!-- Central widget (the drop-target welcome panel). Logic lives in code; the
       .ui only provides a container with the hint QLabel inside. -->
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="centralLayout">
    <property name="leftMargin"><number>20</number></property>
    <property name="topMargin"><number>16</number></property>
    <property name="rightMargin"><number>20</number></property>
    <property name="bottomMargin"><number>16</number></property>
    <item>
     <widget class="QLabel" name="welcomeHint">
      <property name="alignment">
       <set>Qt::AlignmentFlag::AlignCenter</set>
      </property>
      <property name="text">
       <string>Drag files or folders here  ·  supported: .mat  .npy  .csv  .msr  ·  or use  File › Open</string>
      </property>
      <property name="styleSheet">
       <string>color: gray; font-size: 12px;</string>
      </property>
     </widget>
    </item>
   </layout>
  </widget>

  <!-- Status bar -->
  <widget class="QStatusBar" name="statusbar"/>

  <!-- Menu bar -->
  <widget class="QMenuBar" name="menubar">
   <widget class="QMenu" name="menuFile">
    <property name="title"><string>&amp;File</string></property>
    <addaction name="actionOpen"/>
    <addaction name="menuOpenRecent"/>
    <addaction name="separator"/>
    <addaction name="actionSave"/>
    <addaction name="separator"/>
    <addaction name="actionQuit"/>

    <widget class="QMenu" name="menuOpenRecent">
     <property name="title"><string>Open &amp;recent</string></property>
    </widget>
   </widget>

   <widget class="QMenu" name="menuEdit">
    <property name="title"><string>&amp;Edit</string></property>
    <addaction name="actionDatasetManager"/>
    <addaction name="actionFilter"/>
    <addaction name="separator"/>
    <addaction name="actionDuplicate"/>
    <addaction name="separator"/>
    <addaction name="actionPreferences"/>
   </widget>

   <widget class="QMenu" name="menuView">
    <property name="title"><string>&amp;View</string></property>
    <addaction name="actionScatter"/>
    <addaction name="actionHistogram"/>
    <addaction name="actionAttributePlot"/>
    <addaction name="separator"/>
    <addaction name="actionRender"/>
    <addaction name="actionShowInfo"/>
    <addaction name="separator"/>
    <addaction name="actionLog"/>
   </widget>

   <widget class="QMenu" name="menuProcess">
    <property name="title"><string>&amp;Process</string></property>
    <addaction name="menuBatchProcessing"/>

    <widget class="QMenu" name="menuBatchProcessing">
     <property name="title"><string>&amp;Batch Processing</string></property>
     <addaction name="actionBatchRender"/>
     <addaction name="actionBatchExport"/>
     <addaction name="actionBatchFilter"/>
    </widget>
   </widget>

   <widget class="QMenu" name="menuAnalysis">
    <property name="title"><string>&amp;Analysis</string></property>
    <addaction name="menuLocPrecision"/>
    <addaction name="actionLocalDensity"/>
    <addaction name="menuTracking"/>

    <widget class="QMenu" name="menuLocPrecision">
     <property name="title"><string>Localization &amp;Precision</string></property>
     <addaction name="actionLocPrecisionFrc"/>
     <addaction name="actionLocPrecisionCrlb"/>
     <addaction name="actionLocPrecisionStdDev"/>
    </widget>

    <widget class="QMenu" name="menuTracking">
     <property name="title"><string>&amp;Tracking</string></property>
     <addaction name="actionParticleTracking"/>
     <addaction name="actionTraceViewer"/>
     <addaction name="actionMsdAnalysis"/>
    </widget>
   </widget>

   <widget class="QMenu" name="menuPlugins">
    <property name="title"><string>&amp;Plugins</string></property>
    <!-- Items added dynamically at runtime from the plugin registry -->
   </widget>

   <widget class="QMenu" name="menuHelp">
    <property name="title"><string>&amp;Help</string></property>
    <addaction name="actionConsole"/>
    <addaction name="actionMemoryMonitor"/>
    <addaction name="separator"/>
    <addaction name="actionAbout"/>
   </widget>

   <addaction name="menuFile"/>
   <addaction name="menuEdit"/>
   <addaction name="menuView"/>
   <addaction name="menuProcess"/>
   <addaction name="menuAnalysis"/>
   <addaction name="menuPlugins"/>
   <addaction name="menuHelp"/>
  </widget>

  <!-- Toolbar -->
  <widget class="QToolBar" name="toolbar">
   <property name="movable"><bool>false</bool></property>
   <attribute name="toolBarArea"><enum>TopToolBarArea</enum></attribute>
   <attribute name="toolBarBreak"><bool>false</bool></attribute>
   <addaction name="toolRect"/>
   <addaction name="toolOval"/>
   <addaction name="toolPolygon"/>
   <addaction name="toolFreehand"/>
   <addaction name="toolLine"/>
   <addaction name="toolPoint"/>
   <addaction name="toolLut"/>
   <addaction name="toolColor"/>
  </widget>

  <!-- ========== Actions ========== -->

  <!-- File menu -->
  <action name="actionOpen">
   <property name="text"><string>&amp;Open…</string></property>
   <property name="shortcut"><string>Ctrl+O</string></property>
  </action>
  <action name="actionSave">
   <property name="text"><string>&amp;Save processed data…</string></property>
   <property name="shortcut"><string>Ctrl+S</string></property>
  </action>
  <action name="actionQuit">
   <property name="text"><string>&amp;Quit</string></property>
   <property name="shortcut"><string>Ctrl+Q</string></property>
  </action>

  <!-- Edit menu -->
  <action name="actionDatasetManager">
   <property name="text"><string>&amp;Dataset manager</string></property>
   <property name="shortcut"><string>Ctrl+D</string></property>
  </action>
  <action name="actionFilter">
   <property name="text"><string>&amp;Filter…</string></property>
   <property name="shortcut"><string>Ctrl+Shift+F</string></property>
  </action>
  <action name="actionDuplicate">
   <property name="text"><string>Dupl&amp;icate</string></property>
   <property name="shortcut"><string>Ctrl+Shift+D</string></property>
  </action>
  <action name="actionPreferences">
   <property name="text"><string>&amp;Preferences…</string></property>
   <property name="shortcut"><string>Ctrl+,</string></property>
  </action>
  <action name="actionMemoryMonitor">
   <property name="text"><string>Monitor &amp;memory…</string></property>
  </action>

  <!-- View menu -->
  <action name="actionScatter">
   <property name="text"><string>&amp;Scatter plot</string></property>
   <property name="shortcut"><string>Ctrl+1</string></property>
  </action>
  <action name="actionHistogram">
   <property name="text"><string>&amp;Histogram</string></property>
   <property name="shortcut"><string>Ctrl+2</string></property>
  </action>
  <action name="actionAttributePlot">
   <property name="text"><string>&amp;Attribute plot</string></property>
   <property name="shortcut"><string>Ctrl+3</string></property>
  </action>
  <action name="actionLog">
   <property name="text"><string>&amp;Log (events)</string></property>
   <property name="shortcut"><string>Ctrl+L</string></property>
  </action>
  <action name="actionConsole">
   <property name="text"><string>&amp;Console (stdout / stderr)</string></property>
   <property name="shortcut"><string>Ctrl+Shift+L</string></property>
  </action>
  <action name="actionBrightnessContrast">
   <!-- Kept for compatibility with the render window's own toolbar; no longer in the main menu. -->
   <property name="text"><string>&amp;Brightness and Contrast…</string></property>
   <property name="shortcut"><string>Ctrl+Shift+C</string></property>
  </action>
  <action name="actionParaView">
   <property name="text"><string>&amp;ParaView</string></property>
   <property name="shortcut"><string>Ctrl+P</string></property>
  </action>

  <!-- View / Process / Analysis actions -->
  <action name="actionRender">
   <property name="text"><string>&amp;Render</string></property>
   <property name="shortcut"><string>Ctrl+R</string></property>
  </action>
  <action name="actionShowInfo">
   <property name="text"><string>Show &amp;Info…</string></property>
   <property name="shortcut"><string>Ctrl+I</string></property>
  </action>

  <!-- Analysis menu -->
  <action name="actionLocPrecisionFrc">
   <property name="text"><string>&amp;FRC  (Fourier Ring Correlation)</string></property>
  </action>
  <action name="actionLocPrecisionCrlb">
   <property name="text"><string>&amp;CRLB  (Cramér-Rao lower bound)</string></property>
  </action>
  <action name="actionLocPrecisionStdDev">
   <property name="text"><string>&amp;StdDev per trace</string></property>
  </action>
  <action name="actionLocalDensity">
   <property name="text"><string>Local &amp;density</string></property>
  </action>

  <!-- Analysis → Tracking (Phase 5 placeholders) -->
  <action name="actionParticleTracking">
   <property name="text"><string>&amp;Particle tracking</string></property>
  </action>
  <action name="actionTraceViewer">
   <property name="text"><string>&amp;Trace viewer</string></property>
  </action>
  <action name="actionMsdAnalysis">
   <property name="text"><string>&amp;MSD analysis</string></property>
  </action>

  <!-- Process → Batch Processing (Phase 5 placeholders) -->
  <action name="actionBatchRender">
   <property name="text"><string>Batch &amp;render…</string></property>
  </action>
  <action name="actionBatchExport">
   <property name="text"><string>Batch &amp;export…</string></property>
  </action>
  <action name="actionBatchFilter">
   <property name="text"><string>Batch &amp;filter…</string></property>
  </action>

  <!-- Help menu -->
  <action name="actionAbout">
   <property name="text"><string>&amp;About</string></property>
  </action>

  <action name="toolRect">
   <property name="text"><string>Rect</string></property>
   <property name="checkable"><bool>true</bool></property>
  </action>
  <action name="toolOval">
   <property name="text"><string>Oval</string></property>
   <property name="checkable"><bool>true</bool></property>
  </action>
  <action name="toolPolygon">
   <property name="text"><string>Polygon</string></property>
   <property name="checkable"><bool>true</bool></property>
  </action>
  <action name="toolFreehand">
   <property name="text"><string>Freehand</string></property>
   <property name="checkable"><bool>true</bool></property>
  </action>
  <action name="toolLine">
   <property name="text"><string>Line</string></property>
   <property name="checkable"><bool>true</bool></property>
  </action>
  <action name="toolPoint">
   <property name="text"><string>Point</string></property>
   <property name="checkable"><bool>true</bool></property>
  </action>
  <action name="toolLut">
   <property name="text"><string>LUT</string></property>
  </action>
